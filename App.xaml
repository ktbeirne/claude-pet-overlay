<Application x:Class="ClaudePetOverlay.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- ペット右クリックメニュー: 吹き出しと同じ暖色サイバー調のカスタムスタイル -->
        <LinearGradientBrush x:Key="PetMenuBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF3D2317" Offset="0" />
            <GradientStop Color="#FF2E1910" Offset="0.6" />
            <GradientStop Color="#FF40211D" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PetMenuBorder" Color="#66FFD9C0" />
        <SolidColorBrush x:Key="PetMenuForeground" Color="#FFFFFBF8" />
        <SolidColorBrush x:Key="PetMenuAccent" Color="#FFFF8F6B" />
        <SolidColorBrush x:Key="PetMenuHover" Color="#3DFF8F6B" />
        <SolidColorBrush x:Key="PetMenuMuted" Color="#FFCC9E82" />

        <Style x:Key="PetMenuSeparator" TargetType="Separator">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Rectangle Height="1" Fill="#33FFD9C0" Margin="14,5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PetMenuItem" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="{StaticResource PetMenuForeground}" />
            <Setter Property="FontFamily" Value="Yu Gothic UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="Transparent"
                                Padding="10,6"
                                Margin="6,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="CheckDot"
                                         Width="7" Height="7"
                                         Fill="{StaticResource PetMenuAccent}"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Left"
                                         Visibility="Hidden" />
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <Path x:Name="SubArrow"
                                      Grid.Column="2"
                                      Data="M0,0 L5,4.5 L0,9 Z"
                                      Fill="{StaticResource PetMenuMuted}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Visibility="Collapsed" />
                                <Popup x:Name="SubPopup"
                                       Placement="Right"
                                       HorizontalOffset="-2"
                                       VerticalOffset="-10"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Fade">
                                    <Border Margin="10"
                                            CornerRadius="12"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource PetMenuBorder}"
                                            Background="{StaticResource PetMenuBackground}"
                                            Padding="0,7">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16"
                                                              ShadowDepth="2"
                                                              Opacity="0.55"
                                                              Color="#FF140905" />
                                        </Border.Effect>
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PetMenuHover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckDot" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#59FFFBF8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PetContextMenu" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Margin="10"
                                CornerRadius="14"
                                BorderThickness="1"
                                BorderBrush="{StaticResource PetMenuBorder}"
                                Background="{StaticResource PetMenuBackground}"
                                Padding="0,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20"
                                                  ShadowDepth="0"
                                                  Opacity="0.6"
                                                  Color="#FFFF9C6B" />
                            </Border.Effect>
                            <StackPanel>
                                <Grid Margin="16,2,16,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="13" Height="13" Margin="0,0,7,0" VerticalAlignment="Center">
                                        <Path Data="M6.5,0 L12,6.5 L6.5,13 L1,6.5 Z" Fill="{StaticResource PetMenuAccent}" />
                                        <Ellipse Width="4" Height="4"
                                                 Fill="#FFFFFBF8"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Grid.Column="1"
                                               Text="CLAUDE PET"
                                               Foreground="{StaticResource PetMenuMuted}"
                                               FontFamily="Segoe UI Variable Display, Yu Gothic UI"
                                               FontSize="10.5"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="4" Height="4" Fill="#FFFFB07A" Margin="0,0,4,0" />
                                        <Ellipse Width="4" Height="4" Fill="#FFFF8F6B" Margin="0,0,4,0" />
                                        <Ellipse Width="4" Height="4" Fill="#FFFFD9A6" />
                                    </StackPanel>
                                </Grid>
                                <Rectangle Height="1" Fill="#33FFD9C0" Margin="14,0,14,6" />
                                <ItemsPresenter />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
