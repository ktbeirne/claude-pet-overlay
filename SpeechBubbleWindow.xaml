<Window x:Class="ClaudePetOverlay.SpeechBubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Pet Speech Bubble"
        Width="420"
        SizeToContent="Height"
        MinHeight="148"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid x:Name="BubbleRoot" Margin="18,18,18,21">
        <Border x:Name="GlowBorder"
                Margin="4"
                Background="#00351E13"
                BorderBrush="#9BFFB08A"
                BorderThickness="1"
                CornerRadius="24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="0"
                                  Opacity="0.72"
                                  Color="#FFFF9C6B" />
            </Border.Effect>
        </Border>

        <Border x:Name="BubbleBorder"
                Padding="4"
                BorderBrush="#FF26140C"
                BorderThickness="2"
                CornerRadius="22">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF3D2317" Offset="0" />
                    <GradientStop Color="#FF2E1910" Offset="0.58" />
                    <GradientStop Color="#FF40211D" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="4"
                                  Opacity="0.38"
                                  Color="#FF140905" />
            </Border.Effect>
            <Border Padding="16,13,18,16"
                    Background="#F7FFFBF8"
                    BorderBrush="#CCFFD9C0"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="AccentBar"
                            Grid.Column="0"
                            CornerRadius="3"
                            Background="#FFFF8F6B">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8"
                                              ShadowDepth="0"
                                              Opacity="0.7"
                                              Color="#FFFF9C6B" />
                        </Border.Effect>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Grid Width="16" Height="16" Margin="0,0,7,0">
                                    <Path Data="M8,0 L15,8 L8,16 L1,8 Z"
                                          Fill="#FFFFA06B" />
                                    <Ellipse Width="5" Height="5"
                                             Fill="#FFFFFFFF"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock x:Name="BubbleHeader"
                                           Foreground="#FF7E5B48"
                                           FontFamily="Segoe UI Variable Display, Yu Gothic UI"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <Border x:Name="StatePill"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="8,3"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#1FFF8F5A"
                                    BorderBrush="#66FF9C6B"
                                    BorderThickness="1"
                                    CornerRadius="9">
                                <TextBlock x:Name="StateText"
                                           Foreground="#FFB35B33"
                                           FontFamily="Yu Gothic UI"
                                           FontSize="10"
                                           FontWeight="Bold" />
                            </Border>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Ellipse Width="5" Height="5" Fill="#FFFFB07A" Margin="0,0,5,0" />
                                <Ellipse Width="5" Height="5" Fill="#FFFF8F6B" Margin="0,0,5,0" />
                                <Ellipse Width="5" Height="5" Fill="#FFFFD9A6" />
                            </StackPanel>
                        </Grid>

                        <Border x:Name="TaskNamePanel"
                                Grid.Row="1"
                                Margin="0,0,0,9"
                                Padding="9,6"
                                Background="#12FF8A51"
                                BorderBrush="#3DFF9C6B"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TASK"
                                           Margin="0,0,8,0"
                                           Foreground="#FFB56A3D"
                                           FontFamily="Segoe UI Variable Display"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="TaskNameText"
                                           Grid.Column="1"
                                           Foreground="#FF553526"
                                           FontFamily="Yu Gothic UI"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="BubbleBody"
                                       Foreground="#FF31190E"
                                       FontFamily="Yu Gothic UI"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       LineHeight="22"
                                       TextWrapping="Wrap"
                                       MaxHeight="92"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <Grid x:Name="MetadataPanel" Grid.Row="3" Margin="0,9,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ElapsedText"
                                       Foreground="#FF9F8578"
                                       FontFamily="Segoe UI Variable Text, Yu Gothic UI"
                                       FontSize="10"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="TaskCountText"
                                       Grid.Column="1"
                                       Foreground="#FF9F8578"
                                       FontFamily="Segoe UI Variable Text, Yu Gothic UI"
                                       FontSize="10"
                                       FontWeight="SemiBold" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Border>

        <Polygon Points="0,0 34,0 17,21"
                 Fill="#FF2E1910"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 Margin="0,0,0,-19" />
        <Polygon Points="0,0 24,0 12,14"
                 Fill="#FFFFFBF8"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 Margin="0,0,0,-11" />
    </Grid>
</Window>
