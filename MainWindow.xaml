<Window x:Class="ClaudePetOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Pet Overlay"
        Width="480"
        Height="520"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid x:Name="PetSurface" Background="Transparent">
        <Image x:Name="FrameA"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="True" />
        <Image x:Name="FrameB"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="True" />

        <Border x:Name="StatusBadge"
                Margin="18"
                Padding="11,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Background="#D9201513"
                BorderBrush="#BFFFE3D1"
                BorderThickness="1"
                CornerRadius="12"
                IsHitTestVisible="False">
            <TextBlock x:Name="StatusText"
                       Foreground="White"
                       FontFamily="Yu Gothic UI"
                       FontSize="12"
                       FontWeight="SemiBold" />
        </Border>
    </Grid>
</Window>
